generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum ExpenseType {
  INCOME
  EXPENSE
}

enum Recurrence {
  DAILY
  WEEKLY
  MONTHLY
}

model Expense {
  id               String      @id @default(auto()) @map("_id") @db.ObjectId
  title            String
  amount           Float
  type             ExpenseType
  category         String
  note             String?
  date             DateTime    @default(now())
  isRecurring      Boolean     @default(false)
  recurrence       Recurrence?
  nextRecurringRun DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([date])
  @@index([type])
  @@index([category])
  @@map("expenses")
}

model Budget {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  category  String
  limit     Float
  month     Int
  year      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([month, year, category])
  @@map("budgets")
}

model Category {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   @unique
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}
